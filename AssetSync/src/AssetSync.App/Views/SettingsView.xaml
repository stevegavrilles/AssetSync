<UserControl x:Class="AssetSync.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
            <TabControl>
                <TabItem Header="Connections">
                    <StackPanel Margin="8">
                        <TextBlock Text="Snipe-IT URL" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SnipeItUrl}" Margin="0,0,0,8"/>
                        <TextBlock Text="Intune Tenant ID" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding IntuneTenantId}" Margin="0,0,0,8"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Sync"/>
                <TabItem Header="Write-Back"/>
                <TabItem Header="Notifications"/>
                <TabItem Header="Application"/>
            </TabControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
