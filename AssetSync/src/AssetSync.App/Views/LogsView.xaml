<UserControl x:Class="AssetSync.App.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:enums="clr-namespace:AssetSync.Core.Enums;assembly=AssetSync.Core">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Logs" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Filter Bar -->
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel Margin="0,0,8,4">
                <TextBlock Text="From" FontSize="11"/>
                <DatePicker SelectedDate="{Binding FilterFromDate}" Width="120"/>
            </StackPanel>
            <StackPanel Margin="0,0,8,4">
                <TextBlock Text="To" FontSize="11"/>
                <DatePicker SelectedDate="{Binding FilterToDate}" Width="120"/>
            </StackPanel>
            <StackPanel Margin="0,0,8,4">
                <TextBlock Text="Min Level" FontSize="11"/>
                <ComboBox ItemsSource="{Binding LogLevels}" SelectedItem="{Binding FilterMinLevel}" Width="100" IsEditable="False"/>
            </StackPanel>
            <StackPanel Margin="0,0,8,4">
                <TextBlock Text="Source" FontSize="11"/>
                <ComboBox ItemsSource="{Binding SourceSystems}" SelectedItem="{Binding FilterSourceSystem}" Width="100" IsEditable="False"/>
            </StackPanel>
            <StackPanel Margin="0,0,8,4">
                <TextBlock Text="Serial" FontSize="11"/>
                <TextBox Text="{Binding FilterSerialNumber, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
            </StackPanel>
            <StackPanel Margin="0,0,8,4">
                <TextBlock Text="Search" FontSize="11"/>
                <TextBox Text="{Binding FilterFreeText, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
            </StackPanel>
        </WrapPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Search" Command="{Binding SearchCommand}" Margin="0,0,4,0"/>
            <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Margin="0,0,4,0"/>
            <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" Margin="0,0,8,0"/>
        </StackPanel>

        <!-- Pagination -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Previous" Command="{Binding PreviousPageCommand}" Margin="0,0,4,0"/>
            <TextBlock Text="{Binding PageInfo}" VerticalAlignment="Center" Margin="4,0,4,0"/>
            <Button Content="Next" Command="{Binding NextPageCommand}" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Log DataGrid -->
        <DataGrid ItemsSource="{Binding LogEntries}" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserAddRows="False" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="140"/>
                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Level}" Value="{x:Static enums:LogLevel.Error}">
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="{x:Static enums:LogLevel.Warning}">
                                    <Setter Property="Foreground" Value="Orange"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Source" Binding="{Binding SourceSystem}" Width="80"/>
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="80"/>
                <DataGridTextColumn Header="Serial" Binding="{Binding SerialNumber}" Width="120"/>
                <DataGridTextColumn Header="Device" Binding="{Binding DeviceName}" Width="120"/>
                <DataGridTextColumn Header="Detail" Binding="{Binding ErrorDetail}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
