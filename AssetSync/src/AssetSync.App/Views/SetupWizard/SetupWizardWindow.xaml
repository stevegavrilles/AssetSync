<Window x:Class="AssetSync.App.Views.SetupWizard.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asset Sync - Setup Wizard" Height="500" Width="600"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <DockPanel>
        <!-- Navigation Buttons -->
        <Border DockPanel.Dock="Bottom" Background="#f0f0f0" Padding="12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back" Command="{Binding GoBackCommand}"
                        Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,8,0" MinWidth="80"/>
                <Button Content="{Binding NextButtonText}" Command="{Binding GoNextCommand}" MinWidth="80"/>
            </StackPanel>
        </Border>

        <!-- Step Content -->
        <StackPanel Margin="24">
            <TextBlock Text="{Binding StepTitle}" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- Step 0: Welcome -->
            <StackPanel Visibility="{Binding CurrentStepIndex, Converter={x:Static local:StepVisibilityConverter.Instance}, ConverterParameter=0}"
                        xmlns:local="clr-namespace:AssetSync.App.Views.SetupWizard">
                <TextBlock Text="This wizard will guide you through connecting Snipe-IT, Intune, and Iru (Kandji)." TextWrapping="Wrap" Margin="0,0,0,12"/>
                <TextBlock Text="Snipe-IT is the source of truth. Device data from your MDM platforms will be synced into Snipe-IT without overwriting existing values." TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Step 1: Snipe-IT -->
            <StackPanel Visibility="{Binding CurrentStepIndex, Converter={x:Static local:StepVisibilityConverter.Instance}, ConverterParameter=1}"
                        xmlns:local="clr-namespace:AssetSync.App.Views.SetupWizard">
                <TextBlock Text="Base URL" Margin="0,0,0,4"/>
                <TextBox Text="{Binding SnipeItUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                <TextBlock Text="API Key" Margin="0,0,0,4"/>
                <TextBox Text="{Binding SnipeItApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Test Connection" Command="{Binding TestSnipeItCommand}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding SnipeItTestResult}" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Step 2: Intune -->
            <StackPanel Visibility="{Binding CurrentStepIndex, Converter={x:Static local:StepVisibilityConverter.Instance}, ConverterParameter=2}"
                        xmlns:local="clr-namespace:AssetSync.App.Views.SetupWizard">
                <TextBlock Text="Tenant ID" Margin="0,0,0,4"/>
                <TextBox Text="{Binding IntuneTenantId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                <TextBlock Text="Client ID (App Registration)" Margin="0,0,0,4"/>
                <TextBox Text="{Binding IntuneClientId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                <TextBlock Text="Client Secret" Margin="0,0,0,4"/>
                <TextBox Text="{Binding IntuneClientSecret, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Test Connection" Command="{Binding TestIntuneCommand}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding IntuneTestResult}" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Step 3: Iru -->
            <StackPanel Visibility="{Binding CurrentStepIndex, Converter={x:Static local:StepVisibilityConverter.Instance}, ConverterParameter=3}"
                        xmlns:local="clr-namespace:AssetSync.App.Views.SetupWizard">
                <TextBlock Text="Base URL" Margin="0,0,0,4"/>
                <TextBox Text="{Binding IruBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                <TextBlock Text="API Token" Margin="0,0,0,4"/>
                <TextBox Text="{Binding IruApiToken, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Test Connection" Command="{Binding TestIruCommand}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding IruTestResult}" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Step 4: Dry Run -->
            <StackPanel Visibility="{Binding CurrentStepIndex, Converter={x:Static local:StepVisibilityConverter.Instance}, ConverterParameter=4}"
                        xmlns:local="clr-namespace:AssetSync.App.Views.SetupWizard">
                <TextBlock Text="Run a dry run to preview what the sync would do. No changes will be written." TextWrapping="Wrap" Margin="0,0,0,12"/>
                <Button Content="Run Dry Run" Command="{Binding RunDryRunCommand}" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                <ProgressBar IsIndeterminate="{Binding IsDryRunning}" Visibility="{Binding IsDryRunning, Converter={StaticResource BoolToVis}}" Height="4" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding DryRunResult}" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Step 5: Complete -->
            <StackPanel Visibility="{Binding CurrentStepIndex, Converter={x:Static local:StepVisibilityConverter.Instance}, ConverterParameter=5}"
                        xmlns:local="clr-namespace:AssetSync.App.Views.SetupWizard">
                <TextBlock Text="Setup is complete! Click Finish to start using Asset Sync." TextWrapping="Wrap" Margin="0,0,0,12"/>
                <TextBlock Text="You can adjust all settings later from the Settings page." Foreground="Gray"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
